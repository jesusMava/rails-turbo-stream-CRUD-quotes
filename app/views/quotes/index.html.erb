<main class="container">
    <div class="header">
      <h1>Quotes</h1>

      <% if flash[:notice] %>
        <div class="notice"><%= flash[:notice] %></div>
      <% end %>
      <%= link_to "New quote",
        new_quote_path,
        class: "btn btn--primary",
        data: { turbo_frame: "second_frame" }
      %>
    </div>

  <%= turbo_frame_tag "second_frame" do %>
    <%= render @quotes %>
  <% end %>
</main>
